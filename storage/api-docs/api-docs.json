        "/api/v1/chats": {
            "get": {
                "tags": [
                    "ChadGPT"
                ],
                "summary": "Получить историю чатов пользователя",
                "operationId": "50ebea88a7127ab895dae733e99705ba",
                "responses": {
                    "200": {
                        "description": "Список чатов пользователя",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/ChatConversation"
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "ChadGPT"
                ],
                "summary": "Отправить сообщение в ChadGPT",
                "operationId": "b1c39c0cb3d03ac1990771c0889ad88e",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "message"
                                ],
                                "properties": {
                                    "message": {
                                        "description": "Текст сообщения",
                                        "type": "string",
                                        "example": "Привет!"
                                    },
                                    "model": {
                                        "description": "Модель ИИ",
                                        "type": "string",
                                        "example": "gpt-4o-mini"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Ответ от ChadGPT"
                    },
                    "422": {
                        "description": "Ошибка валидации"
                    },
                    "500": {
                        "description": "Ошибка сервера"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            },
            "delete": {
                "tags": [
                    "ChadGPT"
                ],
                "summary": "Очистить историю чатов пользователя",
                "operationId": "d3359fa69bfb18a55d4e72f1392bb1e3",
                "responses": {
                    "200": {
                        "description": "История успешно очищена"
                    },
                    "500": {
                        "description": "Ошибка сервера"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
