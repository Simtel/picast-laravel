    "components": {
        "schemas": {
            "ChatConversation": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "user_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "model": {
                        "type": "string",
                        "example": "gpt-4o-mini"
                    },
                    "user_message": {
                        "type": "string",
                        "example": "Привет!"
                    },
                    "ai_response": {
                        "type": "string",
                        "example": "Привет! Чем могу помочь?"
                    },
                    "used_words_count": {
                        "type": "integer",
                        "example": 5
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2025-10-11T10:00:00Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2025-10-11T10:00:00Z"
                    }
                },
                "type": "object"
            },
            "DomainResource": {
                "description": "Domain resource with WHOIS info",
                "properties": {
                    "id": {
                        "description": "Domain ID",
                        "type": "integer"
                    },
                    "name": {
                        "description": "Domain name",
                        "type": "string",
                        "example": "example.com"
                    },
                    "expire_at": {
                        "description": "Expiration date",
                        "type": "string",
                        "format": "date-time"
                    },
                    "whois": {
                        "description": "WHOIS information",
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                },
                "type": "object"
            },
            "Tournament": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "Турнир по шахматам"
                    },
                    "link": {
                        "type": "string",
                        "format": "uri",
                        "example": "https://example.com/tournament/1"
                    },
                    "date": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-06-01"
                    },
                    "date_end": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-06-07"
                    },
                    "city": {
                        "type": "string",
                        "example": "Москва"
                    },
                    "organizer": {
                        "type": "string",
                        "example": "Шахматный клуб"
                    },
                    "guid": {
                        "type": "string",
                        "example": "abc123"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-05-01T10:00:00Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-05-01T10:00:00Z"
                    }
                },
                "type": "object"
            },
            "TournamentDetail": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "Турнир по шахматам"
                    },
                    "link": {
                        "type": "string",
                        "format": "uri",
                        "example": "https://example.com/tournament/1"
                    },
                    "date": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-06-01"
                    },
                    "date_end": {
                        "type": "string",
                        "format": "date",
                        "example": "2026-06-07"
                    },
                    "city": {
                        "type": "string",
                        "example": "Москва"
                    },
                    "organizer": {
                        "type": "string",
                        "example": "Шахматный клуб"
                    },
                    "guid": {
                        "type": "string",
                        "example": "abc123"
                    },
                    "groups": {
                        "type": "array",
                        "items": {
                            "type": "object"
                        }
                    }
                },
                "type": "object"
            },
            "VideoFullResource": {
                "title": "Video Full Resource",
                "description": "Полный ресурс видео",
                "required": [
                    "id",
                    "url"
                ],
                "properties": {
                    "id": {
                        "description": "ID видео",
                        "type": "integer"
                    },
                    "title": {
                        "description": "Заголовок видео",
                        "type": "string"
                    },
                    "url": {
                        "description": "URL видео",
                        "type": "string"
                    },
                    "createdAt": {
                        "description": "Дата создания",
                        "type": "string",
                        "format": "date-time"
                    },
                    "updatedAt": {
                        "description": "Дата обновления",
                        "type": "string",
